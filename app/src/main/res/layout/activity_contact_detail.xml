<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/contact_detail_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top bar: back arrow + QR share icon -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/small_margin"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@android:string/cancel"
            android:padding="@dimen/medium_margin"
            android:src="@drawable/ic_chevron_left_vector" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/qr_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/qr_share"
            android:padding="@dimen/medium_margin"
            android:src="@drawable/ic_qr_code_vector" />
    </LinearLayout>

    <!-- Body scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/bottom_bar"
        app:layout_constraintTop_toBottomOf="@+id/top_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/activity_margin"
            android:paddingBottom="@dimen/normal_margin">

            <!-- Avatar -->
            <ImageView
                android:id="@+id/contact_avatar"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/normal_margin"
                android:contentDescription="@null"
                android:padding="@dimen/medium_margin"
                android:src="@drawable/ic_person_vector"
                android:background="@drawable/circle_background"
                tools:src="@drawable/ic_person_vector" />

            <!-- Name -->
            <org.fossify.commons.views.MyTextView
                android:id="@+id/contact_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/normal_margin"
                android:gravity="center_horizontal"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="John Doe" />

            <!-- Company -->
            <org.fossify.commons.views.MyTextView
                android:id="@+id/contact_company"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/tiny_margin"
                android:alpha="0.7"
                android:gravity="center_horizontal"
                android:textSize="@dimen/normal_text_size"
                android:visibility="gone"
                tools:text="Acme Corp"
                tools:visibility="visible" />

            <!-- Action row: Call / Message / WhatsApp -->
            <LinearLayout
                android:id="@+id/action_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/activity_margin"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout
                    android:id="@+id/action_call"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/small_margin"
                    android:layout_weight="1"
                    android:background="@drawable/bg_action_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/normal_margin">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_call_filled_vector" />

                    <org.fossify.commons.views.MyTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/tiny_margin"
                        android:text="@string/action_call"
                        android:textSize="@dimen/normal_text_size" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/action_message"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/small_margin"
                    android:layout_weight="1"
                    android:background="@drawable/bg_action_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/normal_margin">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_message_vector" />

                    <org.fossify.commons.views.MyTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/tiny_margin"
                        android:text="@string/action_message"
                        android:textSize="@dimen/normal_text_size" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/action_whatsapp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/small_margin"
                    android:layout_weight="1"
                    android:background="@drawable/bg_action_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/normal_margin">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_whatsapp_vector" />

                    <org.fossify.commons.views.MyTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/tiny_margin"
                        android:text="@string/action_whatsapp"
                        android:textSize="@dimen/normal_text_size" />
                </LinearLayout>
            </LinearLayout>

            <!-- Phone numbers card (rows added dynamically) -->
            <LinearLayout
                android:id="@+id/phones_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/activity_margin"
                android:background="@drawable/bg_section_card"
                android:orientation="vertical"
                android:paddingVertical="@dimen/small_margin" />

            <!-- Email card (rows added dynamically) -->
            <LinearLayout
                android:id="@+id/emails_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/normal_margin"
                android:background="@drawable/bg_section_card"
                android:orientation="vertical"
                android:paddingVertical="@dimen/small_margin"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Ringtone row -->
            <LinearLayout
                android:id="@+id/ringtone_row"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/normal_margin"
                android:background="@drawable/bg_section_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/normal_margin">

                <org.fossify.commons.views.MyTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/ringtone"
                    android:textSize="@dimen/normal_text_size" />

                <org.fossify.commons.views.MyTextView
                    android:id="@+id/ringtone_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.7"
                    android:text="@string/ringtone_default"
                    android:textSize="@dimen/normal_text_size" />
            </LinearLayout>

            <!-- Preferred SIM row -->
            <LinearLayout
                android:id="@+id/preferred_sim_row"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/small_margin"
                android:background="@drawable/bg_section_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/normal_margin">

                <org.fossify.commons.views.MyTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/preferred_sim"
                    android:textSize="@dimen/normal_text_size" />

                <org.fossify.commons.views.MyTextView
                    android:id="@+id/preferred_sim_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.7"
                    android:text="@string/preferred_sim_default"
                    android:textSize="@dimen/normal_text_size" />
            </LinearLayout>

            <!-- More expander header -->
            <LinearLayout
                android:id="@+id/more_header"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/normal_margin"
                android:background="@drawable/bg_section_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/normal_margin">

                <org.fossify.commons.views.MyTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/more_details"
                    android:textSize="@dimen/normal_text_size"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/more_chevron"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_down_vector" />
            </LinearLayout>

            <!-- More content (collapsed by default) -->
            <LinearLayout
                android:id="@+id/more_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <include
                    android:id="@+id/more_address"
                    layout="@layout/item_contact_detail_field" />

                <include
                    android:id="@+id/more_birthday"
                    layout="@layout/item_contact_detail_field" />

                <include
                    android:id="@+id/more_notes"
                    layout="@layout/item_contact_detail_field" />

                <include
                    android:id="@+id/more_website"
                    layout="@layout/item_contact_detail_field" />

                <include
                    android:id="@+id/more_im"
                    layout="@layout/item_contact_detail_field" />

                <include
                    android:id="@+id/more_groups"
                    layout="@layout/item_contact_detail_field" />
            </LinearLayout>

            <!-- Per-contact call log header -->
            <LinearLayout
                android:id="@+id/call_log_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/normal_margin"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/small_margin"
                android:visibility="gone"
                tools:visibility="visible">

                <org.fossify.commons.views.MyTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/call_history_for_contact"
                    android:textSize="@dimen/normal_text_size"
                    android:textStyle="bold" />

                <org.fossify.commons.views.MyTextView
                    android:id="@+id/call_log_clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="@dimen/small_margin"
                    android:text="@string/clear"
                    android:textColor="@color/color_missed_call"
                    android:textSize="@dimen/normal_text_size" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/call_log_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/small_margin"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom action bar (sticky) — known contact: Favourite / Edit / More -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_section_card"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/bottom_button_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/bottom_button_1_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_star_vector" />

            <org.fossify.commons.views.MyTextView
                android:id="@+id/bottom_button_1_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/tiny_margin"
                android:text="@string/favourite"
                android:textSize="@dimen/small_text_size" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottom_button_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/bottom_button_2_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_edit_vector" />

            <org.fossify.commons.views.MyTextView
                android:id="@+id/bottom_button_2_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/tiny_margin"
                android:text="@string/edit"
                android:textSize="@dimen/small_text_size" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottom_button_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/bottom_button_3_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_three_dots_vector" />

            <org.fossify.commons.views.MyTextView
                android:id="@+id/bottom_button_3_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/tiny_margin"
                android:text="@string/more"
                android:textSize="@dimen/small_text_size" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
